# KYC Gateway Environment Variables
# Copy this to .env.local and fill in your values

# Celo Alfajores RPC
CELO_ALFAJORES_RPC=https://alfajores-forno.celo-testnet.org

# Issuer wallet private key (KEEP SECRET!)
# For testing, generate a new wallet and get testnet funds from faucet
ISSUER_PRIVATE_KEY=0x...

# Contract addresses (Alfajores - do not change for testnet)
FEDERATED_ATTESTATIONS_ADDRESS=0x70F9314aF173c246669cFb0EEe79F9Cfd9C34ee3
